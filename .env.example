# WeCom (企业微信) self-built app credentials.
# Copy to .env and fill in from the admin console at work.weixin.qq.com.
# Put REAL values in .env (git-ignored) — never in this example file (it is tracked).

WECOM_CORP_ID=        # 我的企业 → 企业信息 → 企业ID
WECOM_AGENT_ID=       # 应用管理 → <your self-built app> → AgentId
WECOM_SECRET=         # 应用管理 → <your self-built app> → Secret

# Callback (接收消息服务器URL) — both 随机生成 in the WeCom config dialog.
# Only needed to clear the 企业可信IP prerequisite.
WECOM_TOKEN=          # the Token from the callback config dialog
WECOM_AES_KEY=        # the EncodingAESKey (43 chars) from the same dialog
